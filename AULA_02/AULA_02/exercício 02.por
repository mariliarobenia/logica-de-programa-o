programa {
  funcao inicio() {
    // Variáveis
        cadeia nome
        real nota1, nota2, media

        // Entrada de dados
        escreva("Qual o seu nome ? ")
        leia(nome)

        escreva("Qual a primeira nota ? ")
        leia(nota1)

        escreva("Qual a segunda nota ? ")
        leia(nota2)

        media = (nota1 + nota2) / 2

        // Saída de dados
        
        escreva("\n O aluno João Silva obteve média final: ", media)
  }
}
